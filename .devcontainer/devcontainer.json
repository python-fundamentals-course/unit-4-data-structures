{
  "name": "Python Fundamentals",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {}
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-python.black-formatter",
        "njpwerner.autodocstring"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "editor.formatOnSave": true,
        "editor.rulers": [79],
        "jupyter.askForKernelRestart": false,
        "notebook.compactView": false,
        "notebook.cellFocusIndicator": "border",
        "notebook.lineNumbers": "on",
        "notebook.showCellStatusBar": "visible",
        "notebook.outputFontSize": 14,
        "notebook.markup.fontSize": 15,
        "workbench.colorCustomizations": {
          "notebook.cellBorderColor": "#37A0F4",
          "notebook.focusedCellBorder": "#FE9000",
          "notebook.inactiveFocusedCellBorder": "#37A0F4",
          "notebook.outputContainerBackgroundColor": "#37A0F41A"
        }
      }
    }
  },
  "postCreateCommand": "pip install -r .devcontainer/requirements.txt -r tests/requirements.txt",
  "forwardPorts": [8888],
  "remoteUser": "vscode"
}
